# COMPOSE_PROJECT_NAME=kowalski
# KOWALSKI_DB_PORT=5432
# KOWALSKI_SERVER_PORT=8080
# KOWALSKI_DAILY_PORT=8081
# JWT_EXPIRY_DAYS=7
