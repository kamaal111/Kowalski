{
  "name": "kowalski-server",
  "type": "module",
  "scripts": {
    "clean": "rm -rf node_modules dist",
    "compile": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "dev": "tsx watch --inspect src/index.ts",
    "download-spec": "tsx scripts/download-openapi-spec.ts",
    "start": "node dist/src/index.js",
    "test": "vitest --run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "@hono/swagger-ui": "^0.5.2",
    "@hono/zod-openapi": "^1.1.5",
    "@kamaalio/kamaal": "^0.7.8",
    "better-auth": "1.3.32",
    "better-sqlite3": "^12.5.0",
    "cheerio": "^1.1.2",
    "drizzle-orm": "0.44.7",
    "hono": "^4.10.3",
    "jose": "^6.1.3",
    "js-yaml": "^4.1.1",
    "pg": "8.16.3",
    "xml2js": "^0.6.2",
    "yahoo-finance2": "^3.10.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@better-auth/cli": "1.3.32",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.9.2",
    "@types/pg": "8.15.6",
    "@types/xml2js": "^0.4.14",
    "drizzle-kit": "^0.31.6",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.6"
  }
}
