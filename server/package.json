{
  "name": "kowalski-server",
  "type": "module",
  "scripts": {
    "clean": "rm -rf node_modules dist",
    "compile": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json --resolve-full-paths",
    "dev": "tsx watch --inspect src/index.ts",
    "download-spec": "tsx scripts/download-openapi-spec.ts",
    "start": "node dist/src/index.js",
    "test": "vitest --run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.2.4",
    "@kamaalio/kamaal": "^0.8.0",
    "better-auth": "1.6.2",
    "better-sqlite3": "^12.8.0",
    "cheerio": "^1.2.0",
    "drizzle-orm": "0.45.2",
    "hono": "^4.12.12",
    "jose": "^6.2.2",
    "js-yaml": "^4.1.1",
    "pg": "8.20.0",
    "pino": "^10.3.1",
    "xml2js": "^0.6.2",
    "yahoo-finance2": "^3.14.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-auth/cli": "1.4.21",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/pg": "8.20.0",
    "@types/xml2js": "^0.4.14",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
