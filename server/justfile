set export
set dotenv-load

PN := "pnpm"
PNR := PN + " run"
PNX := PN + " exec"
TSX := PNX + " tsx"

AUTH_CONFIG := "src/auth/better-auth.ts"
AUTH_SCHEMA := "src/db/schema/better-auth.ts"

SERVER_PORT := "8080"
DAILY_PORT := "8081"
DOCKER_IMAGE := "kowalski-server"
DOCKER_CONTAINER := "kowalski-server"
DOCKER_DATABASE_URL := "postgresql://kowalski_user:kowalski_password@host.docker.internal:5432/kowalski"

# List available commands
default:
    just --list --unsorted

# Start development server
dev-server: prepare migrate
    #!/usr/bin/env zsh

    export DEBUG="true"
    export PORT="{{ SERVER_PORT }}"

    {{ PNR }} dev

# Start daily development server
dev-daily: prepare migrate
    #!/usr/bin/env zsh

    export DEBUG="true"
    export PORT="{{ DAILY_PORT }}"
    export MODE="DAILY"

    {{ PNR }} dev

# Run server
run-server: prepare compile
    #!/usr/bin/env zsh

    export PORT="{{ SERVER_PORT }}"

    {{ PNR }} start

# Build server Docker image
docker-build tag=DOCKER_IMAGE:
    docker build -t {{ tag }} .

# Run server Docker image
docker-run tag=DOCKER_IMAGE host_port=SERVER_PORT:
    docker run --rm --name {{ DOCKER_CONTAINER }} -p {{ host_port }}:{{ SERVER_PORT }} --add-host=host.docker.internal:host-gateway --env-file .env -e PORT={{ SERVER_PORT }} -e DATABASE_URL={{ DOCKER_DATABASE_URL }} {{ tag }}

# Compile server
compile:
    {{ PNR }} compile

# Run TypeScript type checking
typecheck: prepare
    {{ PNR }} typecheck

# Generate authentication database tables
make-auth-tables: prepare
    npx @better-auth/cli generate --config {{ AUTH_CONFIG }} --output {{ AUTH_SCHEMA }} --yes

# Run tests
test: prepare
    {{ PNR }} test

# Generate migrations
make-migrations: clean prepare compile
    {{ PNX }} drizzle-kit generate

# Run database migrations
migrate: prepare
    {{ PNX }} drizzle-kit migrate

# Pull database schema from remote
pull-schema: prepare
    {{ PNX }} drizzle-kit pull

# Push database schema to remote
push-schema: prepare
    {{ PNX }} drizzle-kit push

# Download OpenAPI spec
download-spec output_schema_filepath: prepare
    #!/usr/bin/env zsh

    SERVER_URL="http://localhost:{{ SERVER_PORT }}"

    echo "🚀 Auto-downloading OpenAPI spec to {{ output_schema_filepath }}..."

    # Check if server is already running
    if curl -s --fail --connect-timeout 2 "$SERVER_URL/spec.json" > /dev/null 2>&1
    then
        echo "✅ Server is already running"
        {{ TSX }} scripts/download-openapi-spec.ts "{{ output_schema_filepath }}" "$SERVER_URL"
    else
        echo "🔄 Server not running, starting development server..."
        echo "   This will start the server in the background and download the spec"

        just run-server &

        echo "⏳ Waiting for server to start..."
        for i in {1..30}; do
            if curl -s --fail --connect-timeout 2 "$SERVER_URL/spec.json" > /dev/null 2>&1
            then
                echo "✅ Server is ready!"
                break
            fi
            if [ $i -eq 30 ]
            then
                echo "❌ Server failed to start within 30 seconds"
                kill $(lsof -t -i:{{ SERVER_PORT }}) || true
                exit 1
            fi
            echo "   Attempt $i/30..."
            sleep 1
        done

        npx tsx scripts/download-openapi-spec.ts "{{ output_schema_filepath }}" "$SERVER_URL"

        echo "🛑 Stopping development server..."
        kill $(lsof -t -i:{{ SERVER_PORT }}) || true
        echo "✅ Done! OpenAPI spec saved to {{ output_schema_filepath }}"
    fi

# Clean project
clean:
    {{ PNR }} clean

# Bootstrap the server project
bootstrap: prepare

# Prepare server environment
prepare: install-modules

[private]
install-modules:
    #!/usr/bin/env zsh

    . ~/.zshrc || true
    echo "Y" | {{ PN }} i
