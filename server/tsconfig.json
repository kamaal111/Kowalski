{
  "compilerOptions": {
    "noEmit": false,
    "target": "ESNext",
    "module": "NodeNext",
    "strict": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": ["node"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "outDir": "./dist",
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@test-vars": ["./src/tests/setup.ts"],
      "@/*": ["./src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
